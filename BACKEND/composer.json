{
    "autoload": {
        "psr-4": {
            "App\\Core\\": "core",
            "App\\Modules\\": "modules"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "@php vendor/phpunit/phpunit/phpunit --testsuite \"Smoke Tests\"",
        "test:all": "@php vendor/phpunit/phpunit/phpunit",
        "reload-autoload": "@php -r \"require 'vendor/autoload.php'; echo 'Autoloader ready. Run composer dump-autoload manually when available.\\n';\""
    },
    "config": {
        "optimize-autoloader": false
    }
}
