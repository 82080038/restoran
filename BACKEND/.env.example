# Food & Beverages Management System - Environment Configuration
# Copy this file to .env and update with your actual values
# CRITICAL: Never commit .env to version control!
# CRITICAL: Change DB_PASSWORD and JWT_SECRET before production deployment!
# CRITICAL: Set CORS_ALLOWED_ORIGINS to specific domains (not *) in production!

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
# DB_SOCKET - Leave empty to use TCP connection, set for Unix socket
# XAMPP on Linux: /opt/lampp/var/mysql/mysql.sock
# XAMPP on Windows: (leave empty, uses TCP)
# MAMP on Mac: /Applications/MAMP/tmp/mysql/mysql.sock
# Docker: /var/run/mysqld/mysqld.sock
DB_SOCKET=
DB_NAME=ebp_restaurant_db
DB_USER=ebp_app
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_CHARSET=utf8mb4

# JWT Configuration
# Generate a strong secret: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Application Configuration
# Set APP_ENV=production and APP_DEBUG=false for production
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000/api/v1

# Database Connection Mode
# Set to 'socket' for Unix socket, 'tcp' for TCP connection
DB_CONNECTION_MODE=tcp

# CORS Configuration
# Production: comma-separated list of allowed origins, e.g. https://yourapp.com,https://admin.yourapp.com
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# Email Configuration (for future use)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# SMS Configuration (for future use)
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# WhatsApp Configuration (for future use)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
