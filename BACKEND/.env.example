# EBP Restaurant Backend - Environment Configuration
# Copy this file to .env and update with your actual values
# IMPORTANT: Change DB_PASSWORD and JWT_SECRET before production deployment!

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
# DB_SOCKET - Leave empty to use TCP connection, set for Unix socket
# XAMPP on Linux: /opt/lampp/var/mysql/mysql.sock
# XAMPP on Windows: (leave empty, uses TCP)
# MAMP on Mac: /Applications/MAMP/tmp/mysql/mysql.sock
# Docker: /var/run/mysqld/mysqld.sock
DB_SOCKET=
DB_NAME=ebp_restaurant_db
DB_USER=ebp_app
DB_PASSWORD=ebp_secure_password_2026
DB_CHARSET=utf8mb4

# JWT Configuration
JWT_SECRET=ebp_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000/api/v1

# Database Connection Mode
# Set to 'socket' for Unix socket, 'tcp' for TCP connection
DB_CONNECTION_MODE=tcp

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# Email Configuration (for future use)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# SMS Configuration (for future use)
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# WhatsApp Configuration (for future use)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
